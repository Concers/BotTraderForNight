# ===== Binance API =====
# Sadece Futures yetkisi, para cekme KAPALI olmali!
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret
# Canliya gecmek icin: false
BINANCE_TESTNET=true

# ===== Telegram Bot (Birincil) =====
# @BotFather'dan olustur. /start ile botunla konus, @userinfobot'tan chat_id al
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ===== Telegram Bot (Ikincil - OPSIYONEL) =====
# Ayni mesajlar ikinci bota/chat'e de gider. Bos birakilirsa devre disi.
TELEGRAM_BOT_TOKEN_2=
TELEGRAM_CHAT_ID_2=

# ===== CoinMarketCap (opsiyonel, market cap filtresi icin) =====
CMC_API_KEY=

# ===== Risk Ayarlari =====
MAX_OPEN_TRADES=7
DEFAULT_LEVERAGE=20
CAPITAL_PERCENT_PER_TRADE=14.28
MIN_MARKET_CAP=45000000
MAX_MARKET_CAP=75000000
MIN_CONFIDENCE_SCORE=75
